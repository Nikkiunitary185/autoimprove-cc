{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AutoImprove Eval Schema",
  "description": "SKILL.md 자동개선을 위한 binary assertions 정의 스키마",
  "type": "object",
  "required": ["skill_name", "skill_md_path", "tests"],
  "properties": {
    "skill_name": {
      "type": "string",
      "description": "스킬 이름 (디렉토리명과 동일)"
    },
    "skill_md_path": {
      "type": "string",
      "description": "SKILL.md 파일의 절대 또는 상대 경로"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "eval.json 생성 시각 (ISO 8601)"
    },
    "tests": {
      "type": "array",
      "minItems": 1,
      "description": "테스트 그룹 배열",
      "items": {
        "type": "object",
        "required": ["id", "description", "prompt", "expected_behavior", "assertions"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^test-\\d{3}$",
            "description": "테스트 ID (test-001 형식)"
          },
          "description": {
            "type": "string",
            "description": "테스트 그룹 설명"
          },
          "prompt": {
            "type": "string",
            "description": "사용자가 입력할 프롬프트 (스킬 트리거 시나리오)"
          },
          "expected_behavior": {
            "type": "string",
            "description": "프롬프트에 대한 기대 동작 설명"
          },
          "assertions": {
            "type": "array",
            "minItems": 1,
            "description": "참/거짓으로 판별 가능한 assertion 배열",
            "items": {
              "type": "string",
              "minLength": 10,
              "description": "하나의 binary assertion (TRUE/FALSE로 판정 가능)"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
